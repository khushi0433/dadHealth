# Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Public URL for Stripe redirects (local dev defaults to http://localhost:8080)
NEXT_PUBLIC_SITE_URL=

# PostHog (Project Settings → API Keys)
NEXT_PUBLIC_POSTHOG_KEY=
# Optional; default in code is https://us.i.posthog.com
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Stripe (Dashboard → Developers → API keys / Webhooks → Products)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
# If unset, Pro is never granted from DB alone (avoids false "Pro" locally). Set to "true" only to test Pro UI using user_profile.subscription_status without Stripe.
# TRUST_CACHED_SUBSCRIPTION_STATUS=
STRIPE_WEBHOOK_SECRET=
# Recurring Price IDs for Dad Health Pro (monthly vs annual).
# Use Stripe Price IDs (price_...). Product IDs (prod_...) can also work if product has default_price set.
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
# Optional: trial days on new subscriptions (default 7)
STRIPE_TRIAL_DAYS=7

# Server-only — used by /api/stripe/webhook to update user_profile (Supabase Dashboard → Settings → API)
SUPABASE_SERVICE_ROLE_KEY=

# OneSignal (push notifications)
ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=
NEXT_PUBLIC_ONESIGNAL_APP_ID=

# Protect cron-triggered endpoints
CRON_SECRET=

# After editing, restart `npm run dev` so Next.js picks up changes.
